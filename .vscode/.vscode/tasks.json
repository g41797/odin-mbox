{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Tests",
            "type": "shell",
            "command": "/home/g41797/.local/bin/odin",
            "args": [
                "build",
                "${workspaceFolder}/${input:testPackage}",
                "-build-mode:test",
                "-debug",
                "-o:none",
                "-out:${workspaceFolder}/debug_current"
            ],
            "group": "build",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "testPackage",
            "type": "pickString",
            "description": "Select test package",
            "options": [
                { "label": "tests/block1/", "value": "tests/block1" },
                { "label": "tests/block2/", "value": "tests/block2" },
                { "label": "tests/block3/", "value": "tests/block3" }
            ]
        }
    ]
}
